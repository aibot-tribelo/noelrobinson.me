---
import Layout from '../layouts/Layout.astro';
import {
  siGithub, siX, siInstagram, siSpotify,
} from 'simple-icons';

const social = [
  { name: 'LinkedIn', url: 'https://www.linkedin.com/in/noelarobinson/', path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
  { name: 'GitHub', url: 'https://github.com/pittdog', path: siGithub.path },
  { name: 'X', url: 'https://x.com/noelrobinson', path: siX.path },
  { name: 'Instagram', url: 'https://www.instagram.com/noelarobinson/', path: siInstagram.path },
  { name: 'Spotify', url: 'https://open.spotify.com/user/1127314265', path: siSpotify.path },
];

const stats = [
  { value: '25+', label: 'Years' },
  { value: '6', label: 'Live Products' },
  { value: '∞', label: 'Curiosity' },
];

const capabilities = [
  { tag: '01', title: 'AI & Agents', desc: 'Multi-agent orchestration, LLM tooling, autonomous workflows. Claude, Bedrock, OpenClaw.' },
  { tag: '02', title: 'Cloud Native', desc: 'AWS, Azure, Kubernetes, EKS, serverless. Infrastructure as code, GitOps, FluxCD.' },
  { tag: '03', title: 'Cyber Resilience', desc: 'Security hardening, threat prevention, compliance. OWASP, OAuth2, OIDC.' },
  { tag: '04', title: 'Engineering Leadership', desc: 'Building and scaling high-performing teams. Agile, DevOps culture, technical strategy.' },
  { tag: '05', title: 'Frontend & Product', desc: 'React, Next.js, Vue, Astro, Tailwind. Shipping consumer products that people use.' },
  { tag: '06', title: 'Performance & DevOps', desc: 'CI/CD pipelines, JMeter automation, horizontal scaling. Making things fast and reliable.' },
];

const projects = [
  { name: 'AllStreams.gg', url: 'https://www.allstreams.gg', tag: 'Streaming' },
  { name: 'EA Sports FC TV', url: 'https://www.easportsfc.tv', tag: 'Streaming' },
  { name: 'Rocket League TV', url: 'https://www.rocketleague.tv', tag: 'Streaming' },
  { name: 'GTA Roleplay TV', url: 'https://www.gtaroleplay.tv', tag: 'Streaming' },
  { name: 'VALORANT Live', url: 'https://www.valolive.tv', tag: 'Streaming' },
  { name: 'TrustedClient', url: 'https://www.trustedclient.co.uk', tag: 'Fintech' },
  { name: 'On Autopilot', url: 'https://www.onautopilot.co.uk', tag: 'AI' },
  { name: "Helen's Kitchen", url: 'https://helens.kitchen', tag: 'CMS' },
  { name: 'Tribelo', url: 'https://www.tribelo.co.uk', tag: 'Consultancy' },
];

const navItems = [
  { label: 'About', href: '#about' },
  { label: 'Work', href: '#work' },
  { label: 'Projects', href: '#projects' },
  { label: 'CV', href: '/cv' },
];
---

<Layout title="Noel Robinson">

  <!-- HERO — full viewport -->
  <section class="relative min-h-screen flex flex-col justify-end bg-bg overflow-hidden">
    
    <!-- Grain overlay -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 256 256%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noise%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.9%22 numOctaves=%224%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noise)%22/%3E%3C/svg%3E'); background-size: 128px;"></div>

    <!-- Nav -->
    <nav class="fixed top-0 left-0 right-0 z-50 mix-blend-difference">
      <div class="max-w-7xl mx-auto px-6 sm:px-10 h-16 flex items-center justify-between">
        <a href="#" class="font-['Bebas_Neue'] text-white text-2xl tracking-wide">NR</a>
        <div class="hidden sm:flex items-center gap-8">
          {navItems.map(n => (
            <a href={n.href} class="text-xs font-['JetBrains_Mono'] text-white uppercase tracking-widest hover:text-accent transition-colors">{n.label}</a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Hero content -->
    <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-10 pb-16 sm:pb-24 w-full">
      
      <!-- Oversized name -->
      <h1 class="font-['Bebas_Neue'] text-[clamp(4rem,15vw,12rem)] leading-[0.85] text-white mb-6 tracking-tight">
        Noel<br/>Robinson
      </h1>

      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-8">
        <div class="max-w-lg">
          <p class="font-['JetBrains_Mono'] text-accent text-xs uppercase tracking-[0.2em] mb-3">Technology Leader</p>
          <p class="text-text-muted text-base leading-relaxed">
            Building what's next — AI agents, cloud platforms, and products that ship. 25 years of making complex things work.
          </p>
        </div>

        <!-- Stats -->
        <div class="flex gap-10">
          {stats.map(s => (
            <div class="text-center">
              <div class="font-['Bebas_Neue'] text-3xl sm:text-4xl text-white">{s.value}</div>
              <div class="font-['JetBrains_Mono'] text-[10px] text-text-muted uppercase tracking-widest">{s.label}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Social strip -->
      <div class="flex items-center gap-5 mt-10 pt-8 border-t border-border">
        {social.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label={s.name}>
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d={s.path}/></svg>
          </a>
        ))}
        <span class="ml-auto font-['JetBrains_Mono'] text-[10px] text-text-muted tracking-widest hidden sm:block">SCROLL ↓</span>
      </div>
    </div>

    <!-- Accent line -->
    <div class="absolute bottom-0 left-0 right-0 h-[2px] bg-gradient-to-r from-transparent via-accent/40 to-transparent"></div>
  </section>

  <!-- ABOUT / CAPABILITIES -->
  <section id="about" class="bg-bg py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      
      <div class="flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">01</span>
        <div class="flex-1 h-px bg-border"></div>
        <h2 class="font-['Bebas_Neue'] text-4xl sm:text-5xl text-white tracking-wide">What I Do</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-px bg-border">
        {capabilities.map(cap => (
          <div class="bg-bg p-8 sm:p-10 group hover:bg-bg-elevated transition-colors">
            <span class="font-['JetBrains_Mono'] text-[10px] text-accent tracking-widest block mb-4">{cap.tag}</span>
            <h3 class="text-lg font-semibold text-white mb-3 font-['Inter']">{cap.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed font-['Inter']">{cap.desc}</p>
          </div>
        ))}
      </div>

    </div>
  </section>

  <!-- WORK / EXPERIENCE -->
  <section id="work" class="bg-bg-elevated py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">

      <div class="flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">02</span>
        <div class="flex-1 h-px bg-border"></div>
        <h2 class="font-['Bebas_Neue'] text-4xl sm:text-5xl text-white tracking-wide">Experience</h2>
      </div>

      <div class="space-y-0 divide-y divide-border">
        <a href="/cv" class="group flex flex-col sm:flex-row sm:items-center justify-between py-8 hover:pl-4 transition-all">
          <div>
            <h3 class="text-xl font-semibold text-white font-['Inter'] group-hover:text-accent transition-colors">Tribelo</h3>
            <p class="text-sm text-text-muted font-['Inter'] mt-1">Founder & Technology Consultant</p>
          </div>
          <span class="font-['JetBrains_Mono'] text-xs text-text-muted mt-2 sm:mt-0">2019 — PRESENT</span>
        </a>
        <a href="/cv" class="group flex flex-col sm:flex-row sm:items-center justify-between py-8 hover:pl-4 transition-all">
          <div>
            <h3 class="text-xl font-semibold text-white font-['Inter'] group-hover:text-accent transition-colors">National Trust</h3>
            <p class="text-sm text-text-muted font-['Inter'] mt-1">Principal Developer</p>
          </div>
          <span class="font-['JetBrains_Mono'] text-xs text-text-muted mt-2 sm:mt-0">2014 — 2019</span>
        </a>
        <a href="/cv" class="group flex flex-col sm:flex-row sm:items-center justify-between py-8 hover:pl-4 transition-all">
          <div>
            <h3 class="text-xl font-semibold text-white font-['Inter'] group-hover:text-accent transition-colors">Which?</h3>
            <p class="text-sm text-text-muted font-['Inter'] mt-1">Senior Agile Java Developer</p>
          </div>
          <span class="font-['JetBrains_Mono'] text-xs text-text-muted mt-2 sm:mt-0">2012 — 2014</span>
        </a>
        <a href="/cv" class="group flex flex-col sm:flex-row sm:items-center justify-between py-8 hover:pl-4 transition-all">
          <div>
            <h3 class="text-xl font-semibold text-white font-['Inter'] group-hover:text-accent transition-colors">Virgin Media</h3>
            <p class="text-sm text-text-muted font-['Inter'] mt-1">Java Designer / Developer</p>
          </div>
          <span class="font-['JetBrains_Mono'] text-xs text-text-muted mt-2 sm:mt-0">2000 — 2011</span>
        </a>
      </div>

      <div class="mt-10 text-right">
        <a href="/cv" class="font-['JetBrains_Mono'] text-xs text-accent hover:text-white transition-colors tracking-widest uppercase">Full CV →</a>
      </div>

    </div>
  </section>

  <!-- PROJECTS -->
  <section id="projects" class="bg-bg py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">

      <div class="flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">03</span>
        <div class="flex-1 h-px bg-border"></div>
        <h2 class="font-['Bebas_Neue'] text-4xl sm:text-5xl text-white tracking-wide">Projects</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {projects.map(p => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative p-6 bg-surface rounded-sm overflow-hidden hover:bg-bg-elevated transition-all border border-transparent hover:border-accent/20"
          >
            <div class="flex items-start justify-between">
              <div>
                <span class="font-['JetBrains_Mono'] text-[10px] text-accent uppercase tracking-widest block mb-2">{p.tag}</span>
                <h3 class="text-base font-semibold text-white font-['Inter'] group-hover:text-accent transition-colors">{p.name}</h3>
              </div>
              <span class="text-text-muted group-hover:text-accent transition-colors text-sm">↗</span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-bg border-t border-border py-12">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="font-['Bebas_Neue'] text-xl text-white tracking-wide">NR</span>
      <div class="flex items-center gap-5">
        {social.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="text-text-muted hover:text-accent transition-colors" aria-label={s.name}>
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5"><path d={s.path}/></svg>
          </a>
        ))}
      </div>
      <span class="font-['JetBrains_Mono'] text-[10px] text-text-muted">&copy; {new Date().getFullYear()}</span>
    </div>
  </footer>

  <!-- Mobile FAB Nav -->
  <div class="sm:hidden fixed bottom-6 right-6 z-50" style="padding-bottom: env(safe-area-inset-bottom)" id="mobile-nav">
    <div id="nav-menu" class="hidden flex-col items-end gap-2 mb-3">
      {navItems.map(n => (
        <a href={n.href} class="px-4 py-2 text-xs font-['JetBrains_Mono'] text-text bg-surface border border-border rounded-full hover:border-accent hover:text-accent transition-all uppercase tracking-widest">{n.label}</a>
      ))}
    </div>
    <button id="nav-toggle" aria-label="Menu" class="w-12 h-12 rounded-full bg-surface border border-border flex items-center justify-center shadow-lg shadow-black/50 active:scale-95 transition-transform hover:border-accent">
      <svg id="ico-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-white">
        <line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/>
      </svg>
      <svg id="ico-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-white hidden">
        <line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/>
      </svg>
    </button>
  </div>

</Layout>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('nav-menu')!;
  const open = document.getElementById('ico-open')!;
  const close = document.getElementById('ico-close')!;

  toggle.addEventListener('click', () => {
    menu.classList.toggle('hidden');
    menu.classList.toggle('flex');
    open.classList.toggle('hidden');
    close.classList.toggle('hidden');
  });

  menu.addEventListener('click', () => {
    menu.classList.add('hidden');
    menu.classList.remove('flex');
    open.classList.remove('hidden');
    close.classList.add('hidden');
  });

  // Reveal on scroll
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.style.opacity = '1';
        e.target.style.transform = 'translateY(0)';
        obs.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('#about > div, #work > div, #projects > div').forEach(el => {
    (el as HTMLElement).style.opacity = '0';
    (el as HTMLElement).style.transform = 'translateY(24px)';
    (el as HTMLElement).style.transition = 'opacity 0.6s ease, transform 0.6s ease';
    obs.observe(el);
  });
</script>

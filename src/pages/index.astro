---
import Layout from '../layouts/Layout.astro';
import { 
  siGithub, siX, siInstagram, siSpotify,
  siDocker, siKubernetes,
  siTypescript, siJavascript, siKotlin, siReact, siVuedotjs,
  siNextdotjs, siGatsby, siHugo, siSpring, siGraphql,
  siMongodb, siPostgresql, siElasticsearch,
  siFlux, siFastly,
  siHomeassistant, siClaude, siWebpack
} from 'simple-icons';

const social = [
  { name: 'LinkedIn', url: 'https://www.linkedin.com/in/noelarobinson/', path: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z' },
  { name: 'GitHub', url: 'https://github.com/noelrobinson', path: siGithub.path },
  { name: 'X', url: 'https://x.com/noelrobinson', path: siX.path },
  { name: 'Instagram', url: 'https://www.instagram.com/noelarobinson/', path: siInstagram.path },
  { name: 'Spotify', url: 'https://open.spotify.com/user/1127314265', path: siSpotify.path },
];

const techSections = [
  { title: 'Cloud & Infra', items: [
    { name: 'AWS', url: 'https://aws.amazon.com/' },
    { name: 'Azure', url: 'https://azure.microsoft.com/' },
    { name: 'Kubernetes', url: 'https://kubernetes.io/', path: siKubernetes.path },
    { name: 'Lambda', url: 'https://aws.amazon.com/lambda/' },
    { name: 'Amplify', url: 'https://aws.amazon.com/amplify/' },
    { name: 'Fastly', url: 'https://www.fastly.com/', path: siFastly.path },
    { name: 'FluxCD', url: 'https://fluxcd.io/', path: siFlux.path },
    { name: 'Docker', url: 'https://www.docker.com/', path: siDocker.path },
  ]},
  { title: 'Languages', items: [
    { name: 'TypeScript', url: 'https://www.typescriptlang.org/', path: siTypescript.path },
    { name: 'JavaScript', url: 'https://www.javascript.com/', path: siJavascript.path },
    { name: 'Kotlin', url: 'https://kotlinlang.org/', path: siKotlin.path },
    { name: 'Java', url: 'https://docs.oracle.com/javase/' },
  ]},
  { title: 'Frontend', items: [
    { name: 'React', url: 'https://reactjs.org/', path: siReact.path },
    { name: 'Vue.js', url: 'https://vuejs.org/', path: siVuedotjs.path },
    { name: 'Next.js', url: 'https://nextjs.org/', path: siNextdotjs.path },
    { name: 'Gatsby', url: 'https://www.gatsbyjs.com/', path: siGatsby.path },
    { name: 'Hugo', url: 'https://gohugo.io/', path: siHugo.path },
  ]},
  { title: 'Architecture', items: [
    { name: 'REST', url: 'https://restfulapi.net/' },
    { name: 'GraphQL', url: 'https://graphql.org/', path: siGraphql.path },
    { name: 'Micro Front Ends', url: 'https://micro-frontends.org/' },
    { name: 'Module Federation', url: 'https://webpack.js.org/concepts/module-federation/', path: siWebpack.path },
    { name: 'Micronaut', url: 'https://micronaut.io/' },
    { name: 'Spring', url: 'https://spring.io/', path: siSpring.path },
  ]},
  { title: 'Data', items: [
    { name: 'PostgreSQL', url: 'https://www.postgresql.org/', path: siPostgresql.path },
    { name: 'MongoDB', url: 'https://www.mongodb.com/', path: siMongodb.path },
    { name: 'Elasticsearch', url: 'https://www.elastic.co/', path: siElasticsearch.path },
    { name: 'DynamoDB', url: 'https://aws.amazon.com/dynamodb/' },
  ]},
];

const books = [
  { name: 'Accelerate', url: 'https://amzn.to/2PrG24M' },
  { name: 'Multipliers', url: 'https://amzn.to/31lNjFK' },
  { name: 'Turn the Ship Around!', url: 'https://amzn.to/3cIUzSJ' },
  { name: 'Clean Code', url: 'https://amzn.to/2Qy1fua' },
  { name: 'Clean Agile', url: 'https://amzn.to/3w2ibta' },
  { name: 'Building Evolutionary Architecture', url: 'https://amzn.to/3fdPeVb' },
  { name: 'Domain Driven Design', url: 'https://amzn.to/3ssoFPJ' },
  { name: 'Refactoring', url: 'https://amzn.to/3fiV5sq' },
  { name: 'Continuous Delivery', url: 'https://amzn.to/3foWOw2' },
  { name: 'Chasing Excellence', url: 'https://amzn.to/2R2Eb7n' },
  { name: 'How Champions Think', url: 'https://amazon.co.uk/gp/product/1476788642' },
  { name: 'Blockchain Revolution', url: 'https://amazon.co.uk/gp/product/1101980141' },
];

const life = [
  { title: 'Leadership & Delivery', items: [
    { name: 'Agile Manifesto', url: 'https://agilemanifesto.org/' },
    { name: 'DevOps', url: 'https://aws.amazon.com/devops/what-is-devops/' },
    { name: 'CNCF', url: 'https://www.cncf.io/' },
    { name: 'Meetup', url: 'https://www.meetup.com/members/31470592/' },
  ]},
  { title: 'Health & Fitness', items: [
    { name: 'Revival Strength', url: 'https://revival-strength.com/' },
    { name: 'CrossFit Bath', url: 'https://crossfitbath.com/' },
    { name: 'BattleGround Fitness', url: 'https://www.mybattleground.co.uk/' },
    { name: 'Stotherts Rugby', url: 'https://www.pitchero.com/clubs/stothertpitt/' },
    { name: 'Truecoach', url: 'https://app.truecoach.co/' },
  ]},
  { title: 'Family & Community', items: [
    { name: 'Down Syndrome Association', url: 'https://www.downs-syndrome.org.uk/' },
    { name: "Helen's Kitchen", url: 'https://helens.kitchen' },
    { name: 'Lyme Regis', url: 'http://www.lymeregis.org/' },
  ]},
  { title: 'Smart Home & AI', items: [
    { name: 'Home Assistant', url: 'https://www.home-assistant.io/', path: siHomeassistant.path },
    { name: 'SmartThings', url: 'https://www.smartthings.com/' },
    { name: 'Claude', url: 'https://claude.ai/', path: siClaude.path },
  ]},
  { title: 'Listening', items: [
    { name: 'Spotify', url: 'https://open.spotify.com/user/1127314265', path: siSpotify.path },
    { name: 'InfoQ', url: 'https://www.infoq.com/podcasts/' },
    { name: 'ThoughtWorks', url: 'https://www.thoughtworks.com/insights/podcasts' },
    { name: 'SE Daily', url: 'https://softwareengineeringdaily.com/' },
    { name: 'The Cloudcast', url: 'https://www.thecloudcast.net/' },
    { name: 'Fintech Insider', url: 'https://fi.11fs.com/' },
  ]},
];

const navItems = [
  { label: 'Tech', href: '#tech' },
  { label: 'Books', href: '#books' },
  { label: 'Life', href: '#life' },
];
---

<Layout title="Noel Robinson">
  <!-- Nav -->
  <nav class="nav">
    <div class="nav-inner">
      <a href="#" class="nav-logo">NR</a>
      <div class="nav-links">
        {navItems.map(n => (
          <a href={n.href}>{n.label}</a>
        ))}
      </div>
    </div>
  </nav>

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="wrap">
        <p class="hero-label reveal">Tech Leader & Engineer · UK</p>
        <h1 class="hero-name reveal d1">Noel Robinson</h1>
        <p class="hero-bio reveal d2">
          Building high-performing teams and cloud-native platforms.<br class="hide-mobile"/>
          Passionate about DevOps, evolutionary architecture, and shipping great products.
        </p>
        <div class="social-row reveal d3">
          {social.map(s => (
            <a href={s.url} target="_blank" rel="noopener noreferrer" class="social-link" aria-label={s.name}>
              <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20">
                <path d={s.path}/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Tech -->
    <section id="tech" class="section">
      <div class="wrap">
        <h2 class="section-title">Technology</h2>
        <div class="tech-grid">
          {techSections.map(group => (
            <div class="tech-group">
              <h3 class="tech-group-title">{group.title}</h3>
              <div class="tag-wrap">
                {group.items.map(item => (
                  <a href={item.url} target="_blank" rel="noopener noreferrer" class="tag">
                    {item.path && (
                      <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14">
                        <path d={item.path}/>
                      </svg>
                    )}
                    {item.name}
                  </a>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Books -->
    <section id="books" class="section section-alt">
      <div class="wrap">
        <h2 class="section-title">Bookshelf</h2>
        <div class="book-grid">
          {books.map((book, i) => (
            <a href={book.url} target="_blank" rel="noopener noreferrer" class="book-item">
              <span class="book-num">{String(i + 1).padStart(2, '0')}</span>
              <span class="book-name">{book.name}</span>
              <span class="book-arrow">↗</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Life -->
    <section id="life" class="section">
      <div class="wrap">
        <h2 class="section-title">Beyond Code</h2>
        <div class="life-grid">
          {life.map(group => (
            <div class="life-group">
              <h3 class="life-group-title">{group.title}</h3>
              <ul class="life-list">
                {group.items.map(item => (
                  <li>
                    <a href={item.url} target="_blank" rel="noopener noreferrer" class="life-link">
                      {item.path && (
                        <svg viewBox="0 0 24 24" fill="currentColor" width="14" height="14" class="life-icon">
                          <path d={item.path}/>
                        </svg>
                      )}
                      {item.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Footer -->
    <footer class="footer">
      <div class="wrap">
        <p>&copy; {new Date().getFullYear()} Noel Robinson</p>
      </div>
    </footer>
  </main>
</Layout>

<style>
  /* ----- Layout ----- */
  .wrap {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .section {
    padding: 80px 0;
    scroll-margin-top: 60px;
  }

  .section-alt {
    background: var(--bg-alt);
  }

  /* ----- Nav ----- */
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 50;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 14px 20px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-logo {
    font-family: 'Instrument Serif', serif;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
  }

  .nav-links {
    display: flex;
    gap: 24px;
  }

  .nav-links a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg-muted);
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--fg); }

  /* ----- Hero ----- */
  .hero {
    padding: 140px 0 80px;
  }

  .hero-label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--fg-dim);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .hero-name {
    font-size: clamp(2.5rem, 8vw, 5rem);
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }

  .hero-bio {
    font-size: 1.125rem;
    color: var(--fg-muted);
    max-width: 540px;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .social-row {
    display: flex;
    gap: 16px;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--border);
    color: var(--fg-muted);
    transition: all 0.2s;
  }

  .social-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* ----- Tech ----- */
  .section-title {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 48px;
    letter-spacing: -0.02em;
  }

  .tech-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 640px) {
    .tech-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .tech-group-title {
    font-family: 'Outfit', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-dim);
    margin-bottom: 12px;
  }

  .tag-wrap {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    font-size: 0.8125rem;
    font-weight: 500;
    background: var(--bg-alt);
    border: 1px solid var(--border);
    border-radius: 100px;
    color: var(--fg);
    transition: all 0.2s;
    white-space: nowrap;
  }

  .tag:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ----- Books ----- */
  .book-grid {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
  }

  .book-item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 0;
    border-bottom: 1px solid var(--border);
    transition: color 0.2s;
  }

  .book-item:hover {
    color: var(--accent);
  }

  .book-num {
    font-size: 0.75rem;
    color: var(--fg-dim);
    font-weight: 500;
    min-width: 24px;
    font-variant-numeric: tabular-nums;
  }

  .book-name {
    flex: 1;
    font-weight: 500;
  }

  .book-arrow {
    font-size: 0.875rem;
    color: var(--fg-dim);
    transition: color 0.2s;
  }

  .book-item:hover .book-arrow {
    color: var(--accent);
  }

  /* ----- Life ----- */
  .life-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 640px) {
    .life-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (min-width: 768px) {
    .life-grid {
      grid-template-columns: 1fr 1fr 1fr;
    }
  }

  .life-group-title {
    font-family: 'Outfit', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--fg-dim);
    margin-bottom: 12px;
  }

  .life-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .life-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9375rem;
    color: var(--fg-muted);
    transition: color 0.2s;
  }

  .life-link:hover {
    color: var(--accent);
  }

  .life-icon {
    flex-shrink: 0;
  }

  /* ----- Footer ----- */
  .footer {
    padding: 32px 0;
    border-top: 1px solid var(--border);
    text-align: center;
    font-size: 0.8125rem;
    color: var(--fg-dim);
  }

  /* ----- Utilities ----- */
  .hide-mobile {
    display: none;
  }

  @media (min-width: 640px) {
    .hide-mobile { display: inline; }
  }
</style>

<script>
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('reveal');
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.tech-group, .book-item, .life-group').forEach(el => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(16px)';
    el.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
    observer.observe(el);
  });

  // Override reveal for observed elements
  const style = document.createElement('style');
  style.textContent = `.tech-group.reveal, .book-item.reveal, .life-group.reveal { opacity: 1 !important; transform: translateY(0) !important; }`;
  document.head.appendChild(style);
</script>

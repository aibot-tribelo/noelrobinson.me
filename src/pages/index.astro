    { n: 'Docker', u: 'https://www.docker.com/', p: siDocker.path },
  ]},
  { title: 'Languages', items: [
    { n: 'TypeScript', u: 'https://www.typescriptlang.org/', p: siTypescript.path },
    { n: 'JavaScript', u: 'https://www.javascript.com/', p: siJavascript.path },
    { n: 'Python', u: 'https://www.python.org/' },
    { n: 'Kotlin', u: 'https://kotlinlang.org/', p: siKotlin.path },
    { n: 'Java', u: 'https://docs.oracle.com/javase/' },
  ]},
  { title: 'Frontend', items: [

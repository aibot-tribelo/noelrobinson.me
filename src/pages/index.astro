  ]},
  { title: 'Databases & Storage', items: [
    { n: 'PostgreSQL', u: 'https://www.postgresql.org/', p: siPostgresql.path },
    { n: 'Supabase', u: 'https://supabase.com/' },
    { n: 'MongoDB', u: 'https://www.mongodb.com/', p: siMongodb.path },
    { n: 'Elasticsearch', u: 'https://www.elastic.co/', p: siElasticsearch.path },
    { n: 'DynamoDB', u: 'https://aws.amazon.com/dynamodb/' },

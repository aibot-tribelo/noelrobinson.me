const books = [
  { name: 'Accelerate', url: 'https://amzn.to/2PrG24M' },
  { name: 'Multipliers', url: 'https://amzn.to/31lNjFK' },
  { name: 'Turn the Ship Around!', url: 'https://amzn.to/3cIUzSJ' },
  { name: 'Clean Code', url: 'https://amzn.to/2Qy1fua' },
  { name: 'Clean Agile', url: 'https://amzn.to/3w2ibta' },
  { name: 'Building Evolutionary Architecture', url: 'https://amzn.to/3fdPeVb' },
  { name: 'Domain Driven Design', url: 'https://amzn.to/3ssoFPJ' },
  { name: 'Refactoring', url: 'https://amzn.to/3fiV5sq' },
  { name: 'Continuous Delivery', url: 'https://amzn.to/3foWOw2' },
  { name: 'Chasing Excellence', url: 'https://amzn.to/2R2Eb7n' },
  { name: 'How Champions Think', url: 'https://amazon.co.uk/gp/product/1476788642' },
  { name: 'Blockchain Revolution', url: 'https://amazon.co.uk/gp/product/1101980141' },
];

const projects = [
  { name: 'AllStreams.gg', url: 'https://www.allstreams.gg', tag: 'Streaming' },
  { name: 'EA Sports FC TV', url: 'https://www.easportsfc.tv', tag: 'Streaming' },
  { name: 'Rocket League TV', url: 'https://www.rocketleague.tv', tag: 'Streaming' },
  { name: 'GTA Roleplay TV', url: 'https://www.gtaroleplay.tv', tag: 'Streaming' },
  { name: 'VALORANT Live', url: 'https://www.valolive.tv', tag: 'Streaming' },
  { name: 'TrustedClient', url: 'https://www.trustedclient.co.uk', tag: 'Fintech' },
  { name: 'On Autopilot', url: 'https://www.onautopilot.co.uk', tag: 'AI' },
  { name: 'OR9', url: 'https://or9.uk', tag: 'Sports' },
  { name: "Helen's Kitchen", url: 'https://helens.kitchen', tag: 'CMS' },
  { name: 'Tribelo', url: 'https://www.tribelo.co.uk', tag: 'Consultancy' },
];

const leadership = [
  { name: 'Agile Manifesto', url: 'https://agilemanifesto.org/' },
  { name: 'DevOps', url: 'https://aws.amazon.com/devops/what-is-devops/' },
  { name: 'CNCF', url: 'https://www.cncf.io/' },
  { name: 'Meetup', url: 'https://www.meetup.com/members/31470592/' },
];

const lifeGroups = [
  { title: 'Health & Fitness', items: [
    { n: 'Revival Strength', u: 'https://revival-strength.com/' },
    { n: 'CrossFit Bath', u: 'https://crossfitbath.com/' },
    { n: 'BattleGround Fitness', u: 'https://www.mybattleground.co.uk/' },
    { n: 'Stotherts Rugby', u: 'https://www.pitchero.com/clubs/stothertpitt/' },
    { n: 'Truecoach', u: 'https://app.truecoach.co/' },
  ]},
  { title: 'Family & Community', items: [
    { n: 'Down Syndrome Association', u: 'https://www.downs-syndrome.org.uk/' },
    { n: "Helen's Kitchen", u: 'https://helens.kitchen' },
    { n: 'Lyme Regis', u: 'http://www.lymeregis.org/' },
  ]},
  { title: 'Smart Home & Energy', items: [
    { n: 'Home Assistant', u: 'https://www.home-assistant.io/', p: siHomeassistant.path },
    { n: 'Tesla', u: 'https://www.tesla.com/energy' },
    { n: 'Octopus Energy', u: 'https://octopus.energy/' },
    { n: 'SolaX Cloud', u: 'https://www.solaxcloud.com/' },
    { n: 'SmartThings', u: 'https://www.smartthings.com/' },
    { n: 'eWeLink', u: 'https://www.ewelink.cc/' },
  ]},
  { title: 'Trading & Markets', items: [
    { n: 'Binance API', u: 'https://developers.binance.com/' },
    { n: 'Polymarket', u: 'https://polymarket.com/' },
    { n: 'Algorithmic Trading', u: 'https://www.investopedia.com/terms/a/algorithmictrading.asp' },
    { n: 'Presearch Nodes', u: 'https://nodes.presearch.com/' },
  ]},
  { title: 'Hobbies', items: [
    { n: 'Snowboarding', u: 'https://www.burton.com/' },
    { n: 'Golf', u: 'https://toptracer.com/range/' },
  ]},
  { title: 'Podcasts', items: [
    { n: 'Spotify', u: 'https://open.spotify.com/user/1127314265', p: siSpotify.path },
    { n: 'InfoQ', u: 'https://www.infoq.com/podcasts/' },
    { n: 'ThoughtWorks', u: 'https://www.thoughtworks.com/insights/podcasts' },
    { n: 'SE Daily', u: 'https://softwareengineeringdaily.com/' },
    { n: 'The Cloudcast', u: 'https://www.thecloudcast.net/' },
    { n: 'Fintech Insider', u: 'https://fi.11fs.com/' },
    { n: 'Views on Vue', u: 'https://topenddevs.com/podcasts/views-on-vue' },
  ]},
];

const navItems = [
  { label: 'Tech', href: '#tech' },
  { label: 'Projects', href: '#projects' },
  { label: 'Books', href: '#books' },
  { label: 'Life', href: '#life' },
  { label: 'CV', href: '/cv' },
];

const experienceItems = [
  { role: 'Founder & Technology Consultant', co: 'Tribelo', period: '2019 — Present' },
  { role: 'Principal Developer', co: 'National Trust', period: '2014 — 2019' },
  { role: 'Senior Agile Java Developer', co: 'Which?', period: '2012 — 2014' },
  { role: 'Java Designer / Developer', co: 'Virgin Media', period: '2000 — 2011' },
];

const heroTimeline = [
  { label: '2000s', desc: 'Billing systems, IVR, SOA — removing human bottlenecks at scale' },
  { label: '2010s', desc: 'Cloud-native platforms, microservices, GitOps — shipping faster' },
  { label: 'Now', desc: 'AI agents that think, act, and orchestrate — the next leap' },
];
---

<Layout title="Noel Robinson — Technology Leader, AI Architect & Builder">
<main id="main">

  <!-- ═══════════════════════ NAVIGATION ═══════════════════════ -->
  <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 glass-card !rounded-none !border-x-0 !border-t-0 border-b border-glass-border bg-bg/70 backdrop-blur-xl">
    <div class="max-w-7xl mx-auto px-6 sm:px-10 h-16 flex items-center justify-between">
      <a href="#" class="font-['Space_Grotesk'] text-white text-xl font-bold tracking-tight">NR</a>
      <div class="hidden sm:flex items-center gap-8">
        {navItems.map(n => (
          <a href={n.href} class="nav-link text-xs font-['JetBrains_Mono'] text-text-muted uppercase tracking-widest hover:text-accent transition-colors relative">
            {n.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- ═══════════════════════ HERO ═══════════════════════ -->
  <section id="hero" class="relative min-h-screen bg-bg overflow-hidden flex items-center">
    <!-- Dot Grid Background -->
    <div class="absolute inset-0 dot-grid-bg"></div>

    <!-- Gradient Orbs -->
    <div class="gradient-orb gradient-orb-1" data-parallax="0.03"></div>
    <div class="gradient-orb gradient-orb-2" data-parallax="0.05"></div>
    <div class="gradient-orb gradient-orb-3" data-parallax="0.04"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-10 pt-24 sm:pt-32 pb-16 sm:pb-24 w-full">
      <!-- Name -->
      <h1 class="font-['Space_Grotesk'] text-[clamp(3.5rem,11vw,9rem)] leading-[0.9] font-bold mb-6 tracking-tight text-gradient">
        Noel<br/>Robinson
      </h1>

      <!-- Subtitle with typing effect -->
      <p id="typing-subtitle" class="font-['JetBrains_Mono'] text-accent text-sm uppercase tracking-[0.25em] mb-8 typing-cursor">
        <span id="typing-text"></span>
      </p>

      <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-12">
        <!-- Description + Timeline -->
        <div class="max-w-lg">
          <p class="text-text-muted text-base leading-relaxed font-['Inter'] mb-8">
            I've been automating and streamlining business processes through technology since the beginning — first with enterprise systems, then cloud-native platforms, now AI orchestration. The tools keep changing. The obsession doesn't.
          </p>

          <!-- Hero Timeline (vertical with fill line) -->
          <div id="hero-timeline" class="relative pl-8 space-y-4">
            <div class="absolute left-[7px] top-1 bottom-1 w-[2px] bg-border-light"></div>
            <div id="hero-timeline-fill" class="absolute left-[7px] top-1 w-[2px] bg-accent transition-all duration-300" style="height: 0%"></div>
            {heroTimeline.map(({ label, desc }, i) => (
              <div class="relative flex items-baseline gap-4">
                <div class="absolute left-[-25px] top-[6px] w-[10px] h-[10px] rounded-full border-2 border-border-light bg-bg z-10 hero-timeline-dot" data-index={i}></div>
                <span class="font-['JetBrains_Mono'] text-xs text-accent shrink-0 w-12 font-medium">{label}</span>
                <span class="text-sm text-text-muted font-['Inter']">{desc}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Stats Cards -->
        <div class="flex gap-6">
          {[{ v: '25+', l: 'Years' }, { v: '9', l: 'Products' }, { v: '\u221E', l: 'Curiosity' }].map(s => (
            <div class="glass-card px-6 py-5 text-center min-w-[90px]">
              <div class="font-['Space_Grotesk'] text-3xl sm:text-4xl text-white font-bold">{s.v}</div>
              <div class="font-['JetBrains_Mono'] text-xs text-text-muted uppercase tracking-widest mt-1">{s.l}</div>
            </div>
          ))}
        </div>
      </div>

      <!-- Social Links -->
      <div class="flex items-center gap-5 mt-12 pt-8 border-t border-border-light/30">
        {social.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="glow-hover text-text-muted" aria-label={s.name}>
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true"><path d={s.path}/></svg>
          </a>
        ))}
        <span class="ml-auto font-['JetBrains_Mono'] text-xs text-text-faint tracking-widest hidden sm:flex items-center gap-2">
          SCROLL
          <span class="bounce-down inline-block">&#x2193;</span>
        </span>
      </div>
    </div>

    <!-- Bottom gradient line -->
    <div class="absolute bottom-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>
  </section>

  <!-- ═══════════════════════ TECH STACK ═══════════════════════ -->
  <section id="tech" class="bg-bg py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="reveal flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">01</span>
        <div class="flex-1 h-px bg-border-light"></div>
        <h2 class="font-['Space_Grotesk'] text-4xl sm:text-5xl font-bold text-gradient tracking-tight">Tech Stack</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {techGroups.map((group, gi) => (
          <div class="reveal-stagger gradient-border p-6" style={`transition-delay: ${gi * 80}ms`}>
            <h3 class="font-['JetBrains_Mono'] text-xs text-accent uppercase tracking-widest mb-4">{group.title}</h3>
            <div class="flex flex-wrap gap-2">
              {group.items.map(item => (
                <a href={item.u} target="_blank" rel="noopener noreferrer"
                   class="inline-flex items-center gap-1.5 px-3 py-1.5 text-xs text-text-muted bg-surface/50 rounded-full hover:bg-surface-light hover:text-accent border border-border/50 hover:border-accent/30 transition-all font-['Inter']">
                  {item.p && <svg viewBox="0 0 24 24" fill="currentColor" class="w-3 h-3 opacity-40" aria-hidden="true"><path d={item.p}/></svg>}
                  {item.n}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ PROJECTS (BENTO GRID) ═══════════════════════ -->
  <section id="projects" class="bg-bg-elevated py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="reveal flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">02</span>
        <div class="flex-1 h-px bg-border-light"></div>
        <h2 class="font-['Space_Grotesk'] text-4xl sm:text-5xl font-bold text-gradient tracking-tight">Projects</h2>
      </div>

      <!-- Bento Grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 auto-rows-[140px] gap-4">
        {projects.map((p, i) => {
          const isFeatured = i === 0;
          return (
            <a href={p.url} target="_blank" rel="noopener noreferrer"
               class:list={[
                 'reveal-stagger group gradient-border p-6 flex flex-col justify-between relative overflow-hidden',
                 isFeatured ? 'sm:col-span-2 sm:row-span-2' : ''
               ]}
               style={`transition-delay: ${i * 60}ms`}>
              {/* Featured card gradient bg */}
              {isFeatured && (
                <div class="absolute inset-0 bg-gradient-to-br from-accent/10 via-transparent to-blue-500/5 pointer-events-none"></div>
              )}
              <div class="relative z-10">
                <span class="font-['JetBrains_Mono'] text-xs text-accent uppercase tracking-widest block mb-2 opacity-70">{p.tag}</span>
                <h3 class:list={[
                  "font-['Space_Grotesk'] font-semibold text-white group-hover:text-accent transition-colors",
                  isFeatured ? 'text-2xl sm:text-3xl' : 'text-base'
                ]}>{p.name}</h3>
                {isFeatured && (
                  <p class="text-text-muted text-sm mt-3 font-['Inter'] max-w-sm">
                    Aggregating live streams across all gaming categories. The flagship product in the streaming ecosystem.
                  </p>
                )}
              </div>
              <div class="relative z-10 flex items-center justify-between mt-auto">
                <span class="inline-block px-2.5 py-1 text-xs font-['JetBrains_Mono'] text-text-faint bg-surface/40 rounded-full uppercase tracking-wider">{p.tag}</span>
                <span class="text-text-muted group-hover:text-accent transition-colors text-sm">&#x2197;</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ BOOKSHELF ═══════════════════════ -->
  <section id="books" class="bg-bg py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="reveal flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">03</span>
        <div class="flex-1 h-px bg-border-light"></div>
        <h2 class="font-['Space_Grotesk'] text-4xl sm:text-5xl font-bold text-gradient tracking-tight">Bookshelf</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {books.map((book, i) => (
          <a href={book.url} target="_blank" rel="noopener noreferrer"
             class="reveal-stagger group glass-card flex items-center gap-4 px-5 py-4 hover:border-accent/20"
             style={`transition-delay: ${i * 50}ms`}>
            <span class="font-['JetBrains_Mono'] text-xs text-text-faint w-5 shrink-0">{String(i + 1).padStart(2, '0')}</span>
            <span class="text-sm font-medium text-text group-hover:text-accent transition-colors font-['Inter'] flex-1">{book.name}</span>
            <span class="text-xs text-text-muted group-hover:text-accent transition-colors">&#x2197;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ EXPERIENCE (ALTERNATING TIMELINE) ═══════════════════════ -->
  <section id="experience" class="bg-bg-elevated py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="reveal flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">04</span>
        <div class="flex-1 h-px bg-border-light"></div>
        <h2 class="font-['Space_Grotesk'] text-4xl sm:text-5xl font-bold text-gradient tracking-tight">Experience</h2>
      </div>

      <!-- Alternating Timeline -->
      <div id="exp-timeline" class="relative">
        <!-- Timeline center line (desktop) / left line (mobile) -->
        <div class="timeline-line"></div>
        <div id="exp-timeline-fill" class="timeline-line-fill"></div>

        <div class="space-y-12 md:space-y-16">
          {experienceItems.map((job, i) => {
            const isLeft = i % 2 === 0;
            return (
              <div class="reveal-stagger relative" style={`transition-delay: ${i * 100}ms`}>
                <!-- Timeline dot -->
                <div class="timeline-dot" style={`top: 28px`} data-timeline-dot></div>

                <!-- Card -->
                <a href="/cv" class:list={[
                  'group block glass-card p-6 relative',
                  'md:w-[calc(50%-32px)]',
                  isLeft ? 'md:mr-auto' : 'md:ml-auto',
                  'ml-10 md:ml-auto',
                ]}>
                  {/* Connector line to dot on desktop */}
                  <div class:list={[
                    'hidden md:block absolute top-7 w-6 h-[2px] bg-border-light',
                    isLeft ? 'right-[-25px]' : 'left-[-25px]',
                  ]}></div>
                  <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-2">
                    <div>
                      <h3 class="text-base font-semibold text-white font-['Space_Grotesk'] group-hover:text-accent transition-colors">{job.role}</h3>
                      <p class="text-sm text-text-muted font-['Inter'] mt-1">{job.co}</p>
                    </div>
                    <span class="font-['JetBrains_Mono'] text-xs text-text-faint shrink-0">{job.period}</span>
                  </div>
                </a>
              </div>
            );
          })}
        </div>
      </div>

      <div class="mt-12 text-center">
        <a href="/cv" class="inline-block glass-card px-6 py-3 font-['JetBrains_Mono'] text-xs text-accent hover:text-white transition-colors tracking-widest uppercase glow-hover">
          Full CV &#x2192;
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ LEADERSHIP ═══════════════════════ -->
  <section class="bg-bg py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="reveal flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">05</span>
        <div class="flex-1 h-px bg-border-light"></div>
        <h2 class="font-['Space_Grotesk'] text-4xl sm:text-5xl font-bold text-gradient tracking-tight">Leadership</h2>
      </div>

      <div class="flex flex-wrap gap-3">
        {leadership.map((item, i) => (
          <a href={item.url} target="_blank" rel="noopener noreferrer"
             class="reveal-stagger glass-card px-6 py-3 text-sm font-medium text-text hover:text-accent transition-all font-['Inter'] glow-hover"
             style={`transition-delay: ${i * 80}ms`}>
            {item.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ BEYOND CODE ═══════════════════════ -->
  <section id="life" class="bg-bg-elevated py-24 sm:py-32 scroll-mt-16">
    <div class="max-w-7xl mx-auto px-6 sm:px-10">
      <div class="reveal flex items-center gap-4 mb-16">
        <span class="font-['JetBrains_Mono'] text-accent text-xs tracking-[0.2em]">06</span>
        <div class="flex-1 h-px bg-border-light"></div>
        <h2 class="font-['Space_Grotesk'] text-4xl sm:text-5xl font-bold text-gradient tracking-tight">Beyond Code</h2>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {lifeGroups.map((group, gi) => (
          <div class="reveal-stagger gradient-border p-6" style={`transition-delay: ${gi * 80}ms`}>
            <h3 class="font-['JetBrains_Mono'] text-xs text-accent uppercase tracking-widest mb-4">{group.title}</h3>
            <div class="space-y-2">
              {group.items.map(item => (
                <a href={item.u} target="_blank" rel="noopener noreferrer"
                   class="flex items-center gap-2.5 text-sm text-text-muted hover:text-accent transition-colors font-['Inter'] py-1 glow-hover">
                  {item.p ? (
                    <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5 opacity-40" aria-hidden="true"><path d={item.p}/></svg>
                  ) : (
                    <span class="w-1.5 h-1.5 rounded-full bg-accent/20 shrink-0"></span>
                  )}
                  {item.n}
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════ FOOTER ═══════════════════════ -->
  <footer class="bg-bg py-12 relative">
    <div class="absolute top-0 left-0 right-0 h-[1px] bg-gradient-to-r from-transparent via-accent/20 to-transparent"></div>
    <div class="max-w-7xl mx-auto px-6 sm:px-10 flex flex-col sm:flex-row items-center justify-between gap-4">
      <span class="font-['Space_Grotesk'] text-xl text-white font-bold tracking-tight">NR</span>
      <div class="flex items-center gap-5">
        {social.map(s => (
          <a href={s.url} target="_blank" rel="noopener noreferrer" class="glow-hover text-text-muted" aria-label={s.name}>
            <svg viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5" aria-hidden="true"><path d={s.path}/></svg>
          </a>
        ))}
      </div>
      <span class="font-['JetBrains_Mono'] text-xs text-text-faint">&copy; {new Date().getFullYear()}</span>
    </div>
  </footer>

  <!-- ═══════════════════════ MOBILE FAB ═══════════════════════ -->
  <div class="sm:hidden fixed bottom-6 right-6 z-50" style="padding-bottom: env(safe-area-inset-bottom)" id="mobile-nav">
    <div id="nav-menu" class="hidden flex-col items-end gap-2 mb-3">
      {navItems.map(n => (
        <a href={n.href} class="glass-card px-4 py-2 text-xs font-['JetBrains_Mono'] text-text uppercase tracking-widest hover:text-accent hover:border-accent/30 transition-all">{n.label}</a>
      ))}
    </div>
    <button id="nav-toggle" aria-label="Menu" class="glass-card w-12 h-12 !rounded-full flex items-center justify-center shadow-lg shadow-black/50 active:scale-95 transition-transform hover:border-accent/30">
      <svg id="ico-open" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-white">
        <line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/>
      </svg>
      <svg id="ico-close" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="w-5 h-5 text-white hidden">
        <line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/>
      </svg>
    </button>
  </div>

</main>
</Layout>

<script>
  // ── Mobile Nav Toggle ──
  const toggle = document.getElementById('nav-toggle')!;
  const menu = document.getElementById('nav-menu')!;
  const open = document.getElementById('ico-open')!;
  const close = document.getElementById('ico-close')!;
  toggle.addEventListener('click', () => {
    menu.classList.toggle('hidden'); menu.classList.toggle('flex');
    open.classList.toggle('hidden'); close.classList.toggle('hidden');
  });
  menu.addEventListener('click', () => {
    menu.classList.add('hidden'); menu.classList.remove('flex');
    open.classList.remove('hidden'); close.classList.add('hidden');
  });

  // ── Typing Effect (cycles phrases, then shows all) ──
  const typingEl = document.getElementById('typing-text');
  const phrases = ['Technology Leader', 'AI Architect', 'Builder'];
  let phraseIndex = 0;
  let charIndex = 0;
  let isDeleting = false;

  function typeLoop() {
    if (!typingEl) return;
    const currentPhrase = phrases[phraseIndex];

    if (isDeleting) {
      charIndex--;
    } else {
      charIndex++;
    }

    // Build display: completed phrases + current typing
    const completed = phrases.slice(0, phraseIndex);
    let display = '';
    if (completed.length > 0) {
      display = completed.join(' \u00B7 ') + ' \u00B7 ';
    }
    display += currentPhrase.substring(0, charIndex);
    typingEl.textContent = display;

    let speed = 80;
    if (isDeleting) speed = 40;

    if (!isDeleting && charIndex === currentPhrase.length) {
      if (phraseIndex === phrases.length - 1) {
        // Last phrase done — show final combined string
        typingEl.textContent = phrases.join(' \u00B7 ');
        setTimeout(() => {
          const cursor = document.getElementById('typing-subtitle');
          if (cursor) cursor.classList.remove('typing-cursor');
        }, 2000);
        return;
      }
      speed = 1500; // pause before deleting
      isDeleting = true;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      phraseIndex++;
    }

    setTimeout(typeLoop, speed);
  }
  setTimeout(typeLoop, 600);

  // ── Scroll-triggered Reveals with Stagger ──
  const revealObs = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).classList.add('revealed');
        revealObs.unobserve(e.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.reveal, .reveal-stagger').forEach(el => {
    revealObs.observe(el);
  });

  // ── Hero Timeline Fill ──
  const heroTimelineFill = document.getElementById('hero-timeline-fill');
  const heroTimelineDots = document.querySelectorAll('.hero-timeline-dot');
  const heroTimelineContainer = document.getElementById('hero-timeline');

  function updateHeroTimeline() {
    if (!heroTimelineFill || !heroTimelineContainer) return;
    const rect = heroTimelineContainer.getBoundingClientRect();
    const windowH = window.innerHeight;
    const progress = Math.max(0, Math.min(1, (windowH - rect.top) / (rect.height + windowH * 0.3)));
    const fillPct = progress * 100;
    heroTimelineFill.style.height = fillPct + '%';

    heroTimelineDots.forEach((dot, i) => {
      const threshold = ((i + 1) / (heroTimelineDots.length + 0.5));
      if (progress >= threshold) {
        dot.classList.add('!border-accent');
        (dot as HTMLElement).style.boxShadow = '0 0 8px var(--color-accent-muted)';
      }
    });
  }

  // ── Experience Timeline Fill ──
  const expTimelineFill = document.getElementById('exp-timeline-fill');
  const expTimeline = document.getElementById('exp-timeline');
  const expDots = document.querySelectorAll('[data-timeline-dot]');

  function updateExpTimeline() {
    if (!expTimelineFill || !expTimeline) return;
    const rect = expTimeline.getBoundingClientRect();
    const windowH = window.innerHeight;
    const scrolled = windowH - rect.top;
    const total = rect.height;
    const progress = Math.max(0, Math.min(1, scrolled / total));
    expTimelineFill.style.height = (progress * 100) + '%';

    expDots.forEach((dot, i) => {
      const dotThreshold = (i + 0.5) / expDots.length;
      if (progress >= dotThreshold) {
        dot.classList.add('active');
      }
    });
  }

  // ── Parallax on Gradient Orbs ──
  const orbs = document.querySelectorAll('[data-parallax]');
  let scrollY = 0;
  let ticking = false;

  function updateParallax() {
    orbs.forEach(orb => {
      const speed = parseFloat((orb as HTMLElement).dataset.parallax || '0');
      (orb as HTMLElement).style.transform = `translateY(${scrollY * speed * -1}px)`;
    });
    ticking = false;
  }

  // ── Active Nav Indicator ──
  const sections = document.querySelectorAll('section[id]');
  const navLinks = document.querySelectorAll('.nav-link');

  function updateActiveNav() {
    let current = '';
    sections.forEach(section => {
      const rect = section.getBoundingClientRect();
      if (rect.top <= 100 && rect.bottom > 100) {
        current = section.id;
      }
    });
    navLinks.forEach(link => {
      const href = link.getAttribute('href');
      if (href === '#' + current) {
        link.classList.add('text-accent');
        link.classList.remove('text-text-muted');
      } else {
        link.classList.remove('text-accent');
        link.classList.add('text-text-muted');
      }
    });
  }

  // ── Unified Scroll Handler ──
  window.addEventListener('scroll', () => {
    scrollY = window.scrollY;
    if (!ticking) {
      requestAnimationFrame(() => {
        updateParallax();
        updateHeroTimeline();
        updateExpTimeline();
        updateActiveNav();
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  // Initial calls
  updateHeroTimeline();
  updateExpTimeline();
  updateActiveNav();
</script>

---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    role: 'Founder & Technology Consultant',
    company: 'Tribelo',
    url: 'https://www.tribelo.co.uk',
    period: '2019 — Present',
    highlights: [
      'Leading cyber resilience programmes — security hardening, threat prevention, compliance',
      'DevOps infrastructure upgrades and automation on AWS, EKS, Kubernetes',
      'Performance test automation with JMeter/Maven and horizontal pod autoscaling',
      'Multi-tenant streaming platforms — single deployment serving multiple domains',
      'AI agent orchestration using Claude, Amazon Bedrock, and OpenClaw',
      'Algorithmic trading systems (Binance API, Polymarket)',
      'Consumer web products — AllStreams.gg, EASportsFC.tv, RocketLeague.tv',
    ],
  },
  {
    role: 'Principal Developer',
    company: 'National Trust',
    period: '2014 — 2019',
    highlights: [
      'Platform re-architecture — EC2 to containerised Kotlin/Java/Node on Kubernetes (EKS)',
      'GitOps CD pipelines with FluxCD and Jenkins',
      'GraphQL federated gateway over existing REST microservices',
      'Single Sign-On (OAuth2) across all web and mobile applications',
      'Website rebuild — new CMS, APIs, ETLs, event-driven microservices on AWS',
      'Introduced Kotlin to dev teams, improving delivery speed',
    ],
  },
  {
    role: 'Senior Agile Java Developer',
    company: 'Which? (via Mosaic Island)',
    period: '2012 — 2014',
    highlights: [
      'Led greenfield project, growing team to 10 — introduced TDD, CI, agile practices',
      'Customer management & billing transformation on SOA architecture',
      'Spring Batch processing, VAT invoicing, data pipeline consolidation',
    ],
  },
  {
    role: 'Java Designer / Developer → Senior Developer',
    company: 'Virgin Media / Virgin Mobile',
    period: '2000 — 2011',
    highlights: [
      'SOA architecture for billing, customer management, and fraud systems',
      'EU Data Roaming, PCI compliance, B2B reverse logistics',
      'Progressed IVR Developer → Senior IVR → Web Developer → Java Designer/Developer',
    ],
  },
];

const skillGroups = [
  { title: 'AI & Automation', tags: ['Claude', 'OpenClaw', 'Bedrock', 'Multi-Agent', 'OpenAI', 'Whisper', 'ElevenLabs'] },
  { title: 'Cloud & DevOps', tags: ['AWS', 'Azure', 'Vercel', 'Kubernetes', 'EKS', 'Docker', 'FluxCD', 'GitOps', 'Jenkins', 'GitHub Actions', 'Vault', 'Lambda', 'Fargate', 'SQS'] },
  { title: 'Security', tags: ['Cyber Resilience', 'Hardening', 'OWASP', 'OAuth2', 'OIDC', 'JWT', 'Spring Security'] },
  { title: 'Languages', tags: ['TypeScript', 'JavaScript', 'Python', 'Kotlin', 'Java 8–21'] },
  { title: 'Frontend', tags: ['React', 'Next.js', 'Vue.js', 'Astro', 'Tailwind', 'Storybook', 'Micro Frontends'] },
  { title: 'Architecture', tags: ['REST', 'GraphQL', 'Microservices', 'SOA', 'Event-Driven', 'Serverless', 'Spring Boot'] },
  { title: 'Data', tags: ['PostgreSQL', 'Supabase', 'MongoDB', 'Elasticsearch', 'DynamoDB', 'Redis'] },
  { title: 'Testing', tags: ['JMeter', 'TDD', 'Cypress', 'Selenium', 'JUnit', 'Mockito', 'Cucumber', 'REST Assured'] },
];
---

<Layout title="CV — Noel Robinson">
  <main class="max-w-3xl mx-auto px-6 pt-16 sm:pt-24 pb-24 cv-content">

    <!-- Header -->
    <div class="mb-14">
      <div class="flex items-center justify-between mb-6">
        <a href="/" class="text-xs text-[#aaa] hover:text-white transition-colors">← Back</a>
        <button onclick="window.print()" class="text-xs text-[#aaa] hover:text-white transition-colors cursor-pointer flex items-center gap-1.5 print:hidden">
          <svg viewBox="0 0 20 20" fill="currentColor" class="w-3.5 h-3.5"><path fill-rule="evenodd" d="M4.5 2A1.5 1.5 0 003 3.5v2.879a2.5 2.5 0 00-1 2V12a2 2 0 002 2h1v1.5A1.5 1.5 0 006.5 17h7a1.5 1.5 0 001.5-1.5V14h1a2 2 0 002-2V8.379a2.5 2.5 0 00-1-2V3.5A1.5 1.5 0 0014.5 2h-10zM14 6.5V3.5a.5.5 0 00-.5-.5h-7a.5.5 0 00-.5.5v3h8zM6 14v1.5a.5.5 0 00.5.5h7a.5.5 0 00.5-.5V12H6v2z" clip-rule="evenodd"/></svg>
          Download PDF
        </button>
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-white mb-1">Noel Robinson</h1>
      <p class="text-base text-[#ccc] mb-4">Technology Leader · 25+ years</p>
      <p class="text-sm text-[#aaa] leading-relaxed max-w-2xl">
        Hands-on technology leader building high-performing teams and enterprise platforms. Deep expertise in cloud-native architecture, cyber resilience, AI orchestration, and DevOps. Currently focused on multi-agent AI systems and algorithmic trading.
      </p>
      <div class="flex flex-wrap gap-x-5 gap-y-1 mt-5 text-xs">
        <a href="https://www.linkedin.com/in/noelarobinson/" target="_blank" rel="noopener noreferrer" class="text-[#aaa] hover:text-white transition-colors">LinkedIn</a>
        <a href="https://github.com/pittdog" target="_blank" rel="noopener noreferrer" class="text-[#aaa] hover:text-white transition-colors">GitHub</a>
        <a href="https://noelrobinson.me" class="text-[#aaa] hover:text-white transition-colors">noelrobinson.me</a>
        <span class="text-[#aaa]">noel@tribelo.co.uk</span>
      </div>
    </div>

    <!-- Skills as tags -->
    <section class="mb-14">
      <h2 class="text-sm font-semibold text-white uppercase tracking-widest mb-6">Skills</h2>
      <div class="space-y-4">
        {skillGroups.map(group => (
          <div class="flex flex-wrap items-baseline gap-x-2 gap-y-2">
            <span class="text-xs font-semibold text-[#ccc] w-28 shrink-0">{group.title}</span>
            <div class="flex flex-wrap gap-1.5">
              {group.tags.map(tag => (
                <span class="px-2.5 py-1 text-xs text-[#ccc] bg-[#161616] rounded">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Experience -->
    <section class="mb-14">
      <h2 class="text-sm font-semibold text-white uppercase tracking-widest mb-6">Experience</h2>
      <div class="space-y-10">
        {experience.map(job => (
          <div>
            <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-0.5 mb-1">
              <h3 class="text-base font-semibold text-white">{job.role}</h3>
              <span class="text-xs text-[#aaa] font-mono shrink-0">{job.period}</span>
            </div>
            {job.url ? (
              <a href={job.url} target="_blank" rel="noopener noreferrer" class="text-sm text-[#aaa] hover:text-white transition-colors">{job.company}</a>
            ) : (
              <p class="text-sm text-[#aaa]">{job.company}</p>
            )}
            <ul class="mt-3 space-y-1">
              {job.highlights.map(h => (
                <li class="text-sm text-[#bbb] flex gap-2 leading-relaxed">
                  <span class="text-[#666] shrink-0 mt-1.5">•</span>
                  <span>{h}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Education -->
    <section class="mb-14">
      <h2 class="text-sm font-semibold text-white uppercase tracking-widest mb-6">Education</h2>
      <p class="text-sm text-[#bbb]">A Levels: Computer Science, Economics, Religious Studies</p>
      <p class="text-sm text-[#bbb]">Core Spring 2.5 — Skills Matter (Spring Source)</p>
    </section>

    <!-- Footer -->
    <footer class="pt-6 border-t border-[#1a1a1a] text-xs text-[#aaa] print:hidden">
      References available on request
    </footer>

  </main>
</Layout>

<style>
  @media print {
    body {
      background: white !important;
      color: #111 !important;
      font-size: 11px !important;
    }
    .cv-content {
      padding-top: 0 !important;
      max-width: 100% !important;
    }
    h1 { color: #000 !important; font-size: 22px !important; }
    h2 { color: #000 !important; font-size: 13px !important; border-bottom: 1px solid #ddd; padding-bottom: 4px; }
    h3 { color: #111 !important; font-size: 12px !important; }
    p, li, span, a { color: #333 !important; }
    .bg-\[#161616\] { background: #f0f0f0 !important; color: #333 !important; }
    a { text-decoration: none !important; }
    section { margin-bottom: 20px !important; }
    .space-y-10 > * + * { margin-top: 16px !important; }
    nav, .print\:hidden { display: none !important; }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Noel Robinson">
  <main class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center">
      <p class="text-sm font-medium text-[#999] uppercase tracking-widest mb-4">404</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">Page not found</h1>
      <p class="text-[#999] mb-8">The page you're looking for doesn't exist.</p>
      <a href="/" class="text-sm font-medium text-white bg-[#161616] hover:bg-[#1e1e1e] px-5 py-2.5 rounded-md transition-all">
        ← Back home
      </a>
    </div>
  </main>
</Layout>

---
interface Props {
	title: string;
	description?: string;
}

const { title, description = "Noel Robinson — Technology Leader. Building high-performing teams, cloud-native platforms, and AI-powered workflows." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://noelrobinson.uk');
import '../styles/global.css';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="canonical" href={canonicalURL.href} />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL.href} />
		<meta name="twitter:card" content="summary" />
		<meta name="twitter:site" content="@noelrobinson" />

		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "Noel Robinson",
			"url": "https://noelrobinson.uk/",
			"jobTitle": "Technology Leader",
			"sameAs": [
				"https://www.linkedin.com/in/noelarobinson/",
				"https://github.com/pittdog",
				"https://x.com/noelrobinson"
			]
		})} />

		<!-- GA4 -->
		<script async src="https://www.googletagmanager.com/gtag/js?id=G-SNK3H67PRP"></script>
		<script is:inline>
			window.dataLayer = window.dataLayer || [];
			function gtag(){dataLayer.push(arguments);}
			gtag('js', new Date());
			gtag('config', 'G-SNK3H67PRP');
		</script>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=JetBrains+Mono:wght@400;500&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
	</head>
	<body>
		<a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:bg-white focus:text-black focus:px-4 focus:py-2 focus:rounded focus:z-[100]">Skip to content</a>
		<slot />
	</body>
</html>
